# BusinessFlow AI — Local Development Environment
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o          # or gpt-35-turbo

# ── Azure SQL ─────────────────────────────────────────────────────────────────
AZURE_SQL_SERVER=<your-server>.database.windows.net
AZURE_SQL_DATABASE=businessflow
AZURE_SQL_USERNAME=<your-username>
AZURE_SQL_PASSWORD=<your-password>

# ── Microsoft Graph API (email trigger) ───────────────────────────────────────
GRAPH_TENANT_ID=<your-tenant-id>
GRAPH_CLIENT_ID=<your-client-id>
GRAPH_CLIENT_SECRET=<your-client-secret>
GRAPH_MONITORED_MAILBOX=inventory@yourcompany.com

# ── Policy Layer ──────────────────────────────────────────────────────────────
POLICY_AUTO_APPROVE_THRESHOLD=50000     # INR — orders below this auto-execute

# ── Azure Storage (Function trigger state) ───────────────────────────────────
AzureWebJobsStorage=UseDevelopmentStorage=true   # use Azurite locally
